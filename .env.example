TZ=America/Chicago
PUID=1000
PGID=1000

# --- Retreivr core ---
RETREIVR_DATA_DIR=/data
RETREIVR_HOST=0.0.0.0
RETREIVR_PORT=8000
RETREIVR_DOWNLOADS_DIR=/downloads
RETREIVR_DEFAULT_VIDEO_FORMAT=mkv
RETREIVR_SCHEDULER_INTERVAL_MINUTES=30
RETREIVR_LOG_LEVEL=INFO

# --- Managed stack roots ---
RETREIVR_MEDIA_ROOT=./media
RETREIVR_MOVIES_ROOT=./media/movies
RETREIVR_TV_ROOT=./media/tv
RETREIVR_DOWNLOADS_ROOT=./downloads
RETREIVR_BOOKS_ROOT=./media/books

# --- Managed stack flags (written by Retreivr UI when you enable services) ---
RETREIVR_STACK_ENABLE_ARR=0
RETREIVR_STACK_ENABLE_RADARR=0
RETREIVR_STACK_ENABLE_SONARR=0
RETREIVR_STACK_ENABLE_READARR=0
RETREIVR_STACK_ENABLE_PROWLARR=0
RETREIVR_STACK_ENABLE_BAZARR=0
RETREIVR_STACK_ENABLE_QBITTORRENT=0
RETREIVR_STACK_ENABLE_VPN=0
RETREIVR_STACK_ENABLE_JELLYFIN=0
RETREIVR_STACK_ENABLE_HOSTCTL=0

# --- Optional external service helpers ---
RETREIVR_HOSTCTL_URL=http://retreivr-hostctl:8010
RETREIVR_QBITTORRENT_BASE_URL=http://qbittorrent:8080
RETREIVR_QBITTORRENT_USERNAME=retreivr
RETREIVR_QBITTORRENT_PASSWORD=
RETREIVR_JELLYFIN_BASE_URL=http://jellyfin:8096
RETREIVR_VPN_CONTROL_URL=http://gluetun:8000/v1/publicip/ip
RETREIVR_VPN_ROUTE_QBITTORRENT=1
RETREIVR_VPN_ROUTE_PROWLARR=0
RETREIVR_VPN_ROUTE_RETREIVR=0

# --- Spotify (Optional) ---
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REDIRECT_URI=http://localhost:8090/api/spotify/callback

# --- Telegram (Optional) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- VPN / Gluetun (Optional; required when torrent traffic is enabled) ---
GLUETUN_PROVIDER=
GLUETUN_OPENVPN_USER=
GLUETUN_OPENVPN_PASSWORD=
GLUETUN_WIREGUARD_PRIVATE_KEY=
GLUETUN_SERVER_COUNTRIES=
